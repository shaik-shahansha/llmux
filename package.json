{
  "name": "llmux",
  "version": "1.0.0",
  "description": "Multiplex every LLM. Never hit a limit.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "hono": "^4.6.3",
    "@hono/node-server": "^1.13.2",
    "ioredis": "^5.4.1",
    "lru-cache": "^11.0.2",
    "p-queue": "^8.0.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.3.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8",
    "tiktoken": "^1.0.17",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.1",
    "node-fetch": "^3.3.2",
    "eventsource-parser": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/js-yaml": "^4.0.9",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3",
    "@vitest/coverage-v8": "^2.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "keywords": ["llm", "ai", "gateway", "openai", "free", "router", "aggregator", "multi-provider", "alloy"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/llmux.git"
  }
}
