# ============================================================
#  LLMux — Environment Variables
#  Copy this file to .env and fill in your API keys.
#  All keys are optional; providers without keys are skipped.
# ============================================================

# ── LLMux Gateway ───────────────────────────────────────────
# Set a secret to require Bearer auth on the gateway itself.
# Leave empty to allow unauthenticated access (dev mode only).
GATEWAY_API_KEY=

# Port to listen on (default: 3000)
PORT=3000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# ── Redis (optional — uses in-memory fallback if unset) ──────
REDIS_URL=redis://localhost:6379

# ── Text Providers ───────────────────────────────────────────
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
HUGGINGFACE_API_KEY=
SAMBANOVA_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_NIM_API_KEY=
GITHUB_MODELS_API_KEY=

# ── New providers (April 2026) ───────────────────────────────
# Moonshot AI (Kimi) — https://platform.moonshot.cn/
KIMI_API_KEY=
# Zhipu AI (GLM) — https://open.bigmodel.cn/
GLM_API_KEY=

# ── Image Providers ──────────────────────────────────────────
# Pollinations: no key needed for basic use
TOGETHER_API_KEY=
FAL_API_KEY=

# ── Audio Providers ──────────────────────────────────────────
# Groq handles both Whisper STT and PlayAI TTS (uses GROQ_API_KEY above)
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
FISH_AUDIO_API_KEY=

# ── Video Providers ──────────────────────────────────────────
REPLICATE_API_KEY=

# ── Config file path (default: config/providers.yaml) ────────
PROVIDERS_CONFIG_PATH=config/providers.yaml
